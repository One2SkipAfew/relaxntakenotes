# Deepgram API Configuration
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_service_role_key_here
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Hugging Face Configuration
HF_TOKEN=your_huggingface_read_token_here

# AI Provider — serverless inference via HF Inference Providers
# Options: "hf-inference" (default, free tier), "novita", "together", "groq"
AI_PROVIDER=hf-inference
AI_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Optional: Legacy dedicated endpoint fallback (leave blank for serverless)
# HF_ENDPOINT_URL=

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://relaxntakenotes.africa,http://localhost:5173,http://localhost:5174

# Budget Configurations
MONTHLY_LIMIT_MINUTES=10000
USER_MONTHLY_LIMIT_MINUTES=180
MAX_RECORDING_DURATION_MINUTES=30

# Upload size limit (bytes) — default 50MB
MAX_UPLOAD_BYTES=52428800

# Google Gemini API (optional — for enhanced fact-checking with grounded search)
# Get a free key at https://aistudio.google.com/apikey
# If not provided, fact-checking falls back to HuggingFace/Llama
GOOGLE_API_KEY=your_google_api_key_here

# Serper API (for web-search-based fact-checking evidence)
# Get a key at https://serper.dev (free tier: 2,500 searches/month)
SERPER_API_KEY=your_serper_api_key_here
